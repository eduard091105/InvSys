pipeline {
    agent any

    environment {
        PYTHONUTF8 = '1'
        VENV_DIR = '.venv'
        INNO_SETUP_COMPILER = 'C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe'
    }

    stages {
        stage('Preparar ambiente') {
            steps {
                bat 'C:\\Users\\danle\\AppData\\Local\\Programs\\Python\\Python313\\python.exe -m venv %VENV_DIR%'
                bat '%VENV_DIR%\\Scripts\\python -m pip install --upgrade pip'
                bat '%VENV_DIR%\\Scripts\\pip install -r inventario-ti\\requirements.txt'
            }
        }

        stage('Build executavel') {
            steps {
                bat 'if exist inventario-ti\\assets\\logo.png %VENV_DIR%\\Scripts\\python inventario-ti\\tools\\create_icon.py'
                bat '%VENV_DIR%\\Scripts\\pyinstaller --clean --noconfirm inventario-ti\\inventario-ti.spec'
            }
        }

        stage('Gerar instalador') {
            steps {
                bat '"%INNO_SETUP_COMPILER%" inventario-ti\\installer\\setup.iss'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'inventario-ti/dist/installer/**', allowEmptyArchive: true
        }
    }
}